; pseudo-code assembler in 6502 assembly 

; data section will start at address 0x5000

; part 1, set up data section
; remember, 6502 is little endian

.org $0000
SOURCE_PTR_LOW: .byte $00
SOURCE_PTR_HIGH: .byte $40

TGT_PTR_LOW: .byte $00
TGT_PTR_HIGH: .byte $50

OPCODE_STR_LOW: .byte $00
OPCODE_STR_HIGH: .byte $70
OPCODE_OFFSET: .byte $00
OPCODE_IDX: .byte $00

TOKEN_BUFFER_PTR: .byte $01

OPCODE_START_IDX: .byte $00

;other scratch space
.org $1000

; temp memory
.org $1500

; opcode directory
.org $2000

; 0 - Implied
; 1 - Immediate
; 2 - Zero Page
; 3 - Zero Page, X
; 4 - Zero Page, Y
; 5 - Absolute
; 6 - Absolute, X
; 7 - Absolute, Y
; 8 - Indrect, X
; 9 - Indirect, Y
; 10 - Accumulator
; 11 - Relative
; 12 - Absolute Indirect


; 13 * 56 = 728
; $2000 - $21FF~ , opcode directory
; $02 illegal placeholder

;opcode index 0

ADC:
.byte $02 ; implied
.byte $69 ; immediate
.byte $65 ; zero page
.byte $75 ; zero page, X
.byte $02 ; zero page, Y
.byte $6D ; absolute
.byte $7D ; absolute, X
.byte $79 ; absolute, Y
.byte $61 ; indirect, x
.byte $71 ; indirect, y
.byte $02 ; accumulator
.byte $02 ; relative
.byte $02 ; absolute indirect

;opcode index 1
AND:

;opcode strings 7000 - 7100
.org $7000   ; 'L'          'D'       'A'
OPCODES_STR: .byte $4C .byte $44 .byte $41  ; ... etc

;dynamic label space 7111 - 7999
.org $7111


;part 2 program section

.org $8000

main:

JSR RESET_OPCODE_IDX

JSR SKIP_SPACES_COMMENTS

PARSE_TOKEN:

LDY #$00
LDA ($00),Y

CMP #$20 ; we could have a space '$20' or newline
BEQ PARSE_OPCODE_ENTRY_LABEL_TOKEN

CMP #$0A
BEQ PARSE_OPCODE_ENTRY_LABEL_TOKEN

PHA

JSR INCREMENT_SOURCE_PTR

PLA

; read string buffer length
LDX $1000
STA $1001,X
INC $1000

JMP PARSE_TOKEN


SKIP_SPACES_COMMENTS:
;at this point we know we are on a fresh 'line', 
LDY #$00
LDA ($00),Y

CMP #$20 ; space case
BEQ SKIP_BYTE

CMP #$0A ; skip newline
BEQ SKIP_BYTE

CMP #3$B ; semi colon
BEQ SKIP_COMMENT

RTS


SKIP_BYTE:
JSR INCREMENT_SOURCE_PTR
JMP SKIP_SPACES_COMMENTS

SKIP_COMMENT:
JSR INCREMENT_SOURCE_PTR
LDY #$00
LDA ($00),Y
CMP #0A
BEQ SKIP_SPACES_COMMENTS
JMP SKIP_COMMENT


INCREMENT_SOURCE_PTR:
LDA $0000
CLC
ADC #$01
STA $0000
LDA $0001
ADC #$00
STA $0001
RTS


PARSE_OPCODE_ENTRY_LABEL_TOKEN:

; check if label
LDX $1000 ; token string length
LDA $1000,X

CMP #$3A
BEQ CREATE_LABEL

LDA $1000
CMP #$03
BNE ERROR_OP_CODE_NOT_FOUND

LDX $0008; load x with buffer pointer

LDA $1000,X

LDX $0006 ; load opcode offset
CMP $7000,X

; if its equal, jump to next opcode character
BEQ CHECK_OPCODE_2

JMP SET_NEXT_OPCODE



CHECK_OPCODE_2:
INC $0008
INC $0006

LDX $0008; load x with buffer pointer

LDA $1000,X

LDX $0006
CMP $7000,X

BEQ CHECK_OPCODE_3
JMP SET_NEXT_OPCODE


CHECK_OPCODE_3:
INC $0008
INC $0006

LDX $0008; load x with buffer pointer

LDA $1000,X

LDX $0006
CMP $7000,X

BEQ FINALIZE_OPCODE
JMP SET_NEXT_OPCODE


FINALIZE_OPCODE:
; at this point we know we have an opcode, but we have to check for operands
; if opcode is of length 1, done, write machine code to output memory
; if opcode is of different type, skip spaces and read in next token
; check supported addressing mode using bit mask
; for now only support hexadecimal
; if the opcode has operands, we output a different hexOpCode depending on the addressing mode
; how to store the opcode variants?
; there are up to 13 variants
; dedicate memory for each opcode index, 13 bytes long, use $02 to represent unsupported address mode
; each 13 bytes represents the opcode of a specific addressing mode, the index 0-12 determines the addressing mode.
; if the implied mode is not $02, it is a 1-length opcode, we just grab the code and jmp to main
; else we need to continue parsing the operand section to figure out the addressing mode and subsequent output operand


SET_NEXT_OPCODE:
;0 - 55 legal
INC $0007 ; op code index
LDA $0007
CMP #$56
BEQ ERROR_OP_CODE_NOT_FOUND

LDA $0009;
ADC #$03;
STA $0009
STA $0006
LDA #$01
STA $0008
JMP PARSE_OPCODE_ENTRY_LABEL_TOKEN


CREATE_LABEL:
; this is the case of a Label creation
; create the label entry record
; jump back to main, output pointer not changed


; the other case of label usage is a label reference in the operand
DECODE_BRANCH_LABEL:


DECODE_OPERAND_LABEL:

RESET_OPCODE_IDX:
LDA #$00
STA $0007
STA $0009
STA $0006
RTS

ERROR_OP_CODE_NOT_FOUND:
LDA #$05 ; use #$05 to represent op code not found error
STA $1500
BRK


















